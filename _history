itchLeft = mappedPitch\n        pitchRight = mappedPitch\n        leftOutput = (pitchLeft + seitLeft) / 2\n        rightOutput = (pitchRight + seitRight) / 2\n        if (rawPitch == 0 && rawSeit == 0) {\n            robotbit.MotorStopAll()\n        } else {\n            if (leftOutput < 0) {\n                robotbit.MotorRun(robotbit.Motors.M1A, leftOutput)\n            }\n            if (rightOutput < 0) {\n                robotbit.MotorRun(robotbit.Motors.M1B, rightOutput)\n            }\n        }\n    }\n})\nlet rightOutput = 0\nlet leftOutput = 0\nlet pitchRight = 0\nlet pitchLeft = 0\nlet mappedPitch = 0\nlet rawPitch = 0\nlet seitRight = 0\nlet seitLeft = 0\nlet mappedSeit = 0\nlet rawSeit = 0\nlet wert = 0\nlet info = \"\"\nlet lauf_flag = 0\nlet Platzhalter = 0\nlet Platzhalter2 = 0\nradio.setGroup(3)\nlauf_flag = 0\nbasic.showIcon(IconNames.Diamond)\nrobotbit.MotorStopAll()\n","README.md":"","pxt.json":"{\n    \"name\": \"talente_fahrzeug_1.1\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\",\n        \"robotbit\": \"github:kittenbot/pxt-robotbit#v0.4.8\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\"\n    ],\n    \"preferredEditor\": \"tsprj\"\n}\n"}}],"shares":[],"lastSaveTime":1778436053804}